  "scripts": {
    "dev:lan-url": "node scripts/print-dev-backend-url.js",
    "start": "react-native start",
    "start:lan": "react-native start --host 0.0.0.0",
    "android:adb-reverse": "adb reverse tcp:8081 tcp:8081",
    "android": "react-native run-android",
    "android:apk:debugRelease": "cd android && ENVFILE=.env ./gradlew assembleDebugRelease && cd ..",
    "android:apk:debugRelease:lan": "cd android && ENVFILE=.env.lan ./gradlew assembleDebugRelease && cd ..",
    "android:install:debugRelease": "cd android && ENVFILE=.env ./gradlew installDebugRelease && cd ..",
    "android:install:debugRelease:lan": "cd android && ENVFILE=.env.lan ./gradlew installDebugRelease && cd ..",
    "android:apk:release": "cd android && ENVFILE=.env.production ./gradlew assembleRelease && cd ..",
    "android:bundle:release": "cd android && ENVFILE=.env.production ./gradlew bundleRelease && cd ..",
    "android:bundle:debug": "cd android && ENVFILE=.env ./gradlew bundleDebug && cd ..",
    "ios": "react-native run-ios",
    "postinstall": "node scripts/create-worklets-stub.js",
    "generate-android-icons": "node scripts/generate-android-icons.js",
    "test:ai-service": "ts-node --project testsprite_tests/backend/tsconfig.json --transpile-only --require ./testsprite_tests/backend/setup.ts testsprite_tests/backend/ai-service.test.ts",
    "test:delivery-logic-api": "ts-node testsprite_tests/backend/delivery-logic-api.test.ts",
    "test:delivery-tiering": "ts-node testsprite_tests/backend/delivery-tiering-calculation.test.ts",
    "test:all": "yarn test:ai-service && yarn test:delivery-logic-api && yarn test:delivery-tiering",
    "load:get-test-data": "node scripts/get-test-data.js",
    "load:performance": "k6 run scripts/performance-test.js",
    "load:websocket": "k6 run scripts/websocket-test.js"
