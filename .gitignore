# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision

# Android keystore properties (contains sensitive passwords)
android/keystore.properties

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local
.env.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
# /android  # Keep android folder - it's needed for bare React Native builds
.env.production
# Phone / LAN dev build (see .env.example — copy from .env, set BACKEND_API_URL to Mac LAN IP)
.env.lan

# backend build and runtime artifacts
backend/bin/
backend/obj/
backend/src/**/bin/
backend/src/**/obj/
backend/logs/
backend/publish/
backend/src/Ay.WebApi/logs/
backend/wwwroot/uploads/

# backend local-only config
backend/appsettings.Development.json
backend/appsettings.*.local.json
