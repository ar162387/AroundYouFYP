# Copy to ".env" at the repo root, then rebuild the Android app (Gradle embeds env at build time).
# Docs: https://github.com/lugg/react-native-config

# --- Required for .NET API (Nearby Shops, auth, orders, etc.) ---
# Port must match backend/Properties/launchSettings.json (default 5017).
# Backend listens on 0.0.0.0:5017 so other devices on your home LAN can connect.
#
# Pick ONE target (phone vs emulator):
#
# • Physical phone + Mac on same home Wi‑Fi (no public IP / no tunnel):
#     Run: yarn dev:lan-url
#     Put the printed line here (replace the BACKEND_API_URL line below).
#     Then: yarn android  (debug builds allow HTTP; see android/app/src/debug/AndroidManifest.xml)
#     If nothing connects, allow inbound TCP 5017 for dotnet in macOS Firewall settings.
#
# • Android emulator → host machine:
# BACKEND_API_URL=http://10.0.2.2:5017
#
# • Production VPS (self-signed HTTPS cert):
#   Android trusts this via android/app/src/main/res/raw/ay_backend_cert.pem
BACKEND_API_URL=https://193.123.68.165
#
# • debugRelease APK on a PHYSICAL phone (JS bundled, no Metro):
#     10.0.2.2 does NOT work on a real device — it will load forever / time out.
#     cp .env .env.lan
#     yarn dev:lan-url   → put that BACKEND_API_URL into .env.lan (not 10.0.2.2)
#     yarn android:apk:debugRelease:lan
#     (Or one-off: ENVFILE=.env.lan ./gradlew assembleDebugRelease from android/)
#
# • iOS Simulator:
# BACKEND_API_URL=http://127.0.0.1:5017
# Optional alias (apiClient accepts either):
# DOTNET_API_URL=http://10.0.2.2:5017

# --- Google Sign-In (Android / web client ID) ---
GOOGLE_WEB_CLIENT_ID=

# --- Maps / places (optional for some screens) ---
GOOGLE_MAPS_API_KEY=
GEOAPIFY_API_KEY=

# --- Optional ---
OPENAI_API_KEY=
GEMINI_API_KEY=
